# Azure Storage Configuration
# Get this from your Azure Storage account in the Azure Portal
# Navigate to: Your Storage Account -> Security + networking -> Access keys
# Copy the "Connection string" value from "key1"

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Note: Replace YOUR_ACCOUNT_NAME and YOUR_ACCOUNT_KEY with your actual values
# Example: DefaultEndpointsProtocol=https;AccountName=mystorageaccount123;AccountKey=abc123...xyz789;EndpointSuffix=core.windows.net
